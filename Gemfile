gem "tzinfo-data"
gem "wdm", "~> 0.1.0" if Gem.win_platform?

# Standard library gems no longer bundled by default in Ruby 3.4+.
# Required by older transitive deps (e.g. httpclient -> algoliasearch).
gem "mutex_m"

# If you have any plugins, put them here!
